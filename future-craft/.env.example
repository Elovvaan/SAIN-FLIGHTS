NATS_URL=nats://localhost:4222
SQLITE_PATH=./data/telemetry.db
LOG_LEVEL=info
VEHICLE_ID=sain-001
PERCEPTION_HTTP_PORT=8010

# ── Hardware mode ──────────────────────────────────────────────────────────────
# FC_HARDWARE_MODE=sim        (default) — uses SimFlightControllerLink (no hardware needed)
# FC_HARDWARE_MODE=mavlink    — uses MavlinkFlightControllerLink (real flight controller)
FC_HARDWARE_MODE=sim

# MAVLink flight-controller endpoint (only used when FC_HARDWARE_MODE=mavlink)
# For ArduPilot SITL: FC_MAVLINK_HOST=127.0.0.1  FC_MAVLINK_PORT=14550
# For real hardware via MAVProxy or serial-to-UDP bridge: set host/port accordingly
FC_MAVLINK_HOST=127.0.0.1
FC_MAVLINK_PORT=14550
FC_MAVLINK_TARGET_SYS=1
