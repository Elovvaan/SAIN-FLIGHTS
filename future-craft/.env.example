NATS_URL=nats://localhost:4222
SQLITE_PATH=./data/telemetry.db
LOG_LEVEL=info
VEHICLE_ID=sain-001
PERCEPTION_HTTP_PORT=8010

# ── Hardware mode ──────────────────────────────────────────────────────────────
# FC_HARDWARE_MODE=sim        (default) — uses SimFlightControllerLink (no hardware needed)
# FC_HARDWARE_MODE=mavlink    — uses MavlinkFlightControllerLink (real flight controller)
FC_HARDWARE_MODE=sim

# MAVLink flight-controller endpoint (only used when FC_HARDWARE_MODE=mavlink)
# For ArduPilot SITL: FC_MAVLINK_HOST=127.0.0.1  FC_MAVLINK_PORT=14550
# For real hardware via MAVProxy or serial-to-UDP bridge: set host/port accordingly
FC_MAVLINK_HOST=127.0.0.1
FC_MAVLINK_PORT=14550
FC_MAVLINK_TARGET_SYS=1

# ── Version-1 tangential-field control mode ────────────────────────────────────
# When true, propulsion-controller routes motion plans through the 4-node field
# solver instead of the flat avgLift model.
# FIELD_MODE_ENABLED=false   (default) — standard avgLift behavior
# FIELD_MODE_ENABLED=true    — Version-1 field mode active
FIELD_MODE_ENABLED=false

# Phase advance rate in radians per second.
# Default ≈ π rad/s (one full rotation every 2 s).
FIELD_PHASE_VELOCITY=3.14159265358979

# Spin direction: ≥ 0 = clockwise (1), < 0 = counter-clockwise (−1).
FIELD_SPIN=1

# Output scale applied to solver results before sending to the FC.
# 1.0 = full [0..1] range; reduce to limit maximum motor power during testing.
FIELD_OUTPUT_SCALE=1

# ── Field translation (velocity-driven directional movement) ───────────────────
# When true, translateField() shifts the field center each tick to produce
# directional movement WITHOUT tilting the craft.
FIELD_TRANSLATION_ENABLED=false
# Gain applied to the translation phase offset (phase radians per unit velocity per second).
FIELD_TRANSLATION_GAIN=0.4
# Gain applied to the lateral bias assist (bias-units per unit velocity per second).
FIELD_BIAS_GAIN=0.1

# ── Execution-layer output mode ────────────────────────────────────────────────
# Controls how solved [A,B,C,D] motor outputs reach the physical ESCs.
#
# FC_OUTPUT_MODE=mixer      (default) — passes outputs to the FC via
#   SET_ACTUATOR_CONTROL_TARGET; the FC's own mixer matrix is applied before
#   the signals reach the ESCs.  Compatible with standard GUIDED mode but NOT
#   guaranteed to preserve the software motor ordering A→B→C→D.
#   ⚠  NOT valid for true field-mode execution.
#
# FC_OUTPUT_MODE=passthrough — maps outputs directly to physical ESC channels
#   (see MOTOR_*_CHANNEL below) before sending to the FC.  For the signals to
#   reach the ESCs without FC remixing:
#     ArduPilot: SERVO_PASS_THRU must be enabled, or a custom motor matrix
#                loaded that maps group-0 controls[0..3] 1-to-1.
#     PX4:       actuator direct mode must be active.
#   Arming is BLOCKED when this mode is selected and any hard condition is
#   not satisfied (see startup log for details).
FC_OUTPUT_MODE=mixer

# ── Motor channel map ──────────────────────────────────────────────────────────
# Physical ESC/PWM channel index (0-based) for each logical motor.
# Default: straight-through (A→0, B→1, C→2, D→3).
# Override when the airframe wires motors in a different order, e.g.:
#   MOTOR_A_CHANNEL=2   if the front-right ESC is wired to FC channel 2.
MOTOR_A_CHANNEL=0
MOTOR_B_CHANNEL=1
MOTOR_C_CHANNEL=2
MOTOR_D_CHANNEL=3

# ── Motor inversion flags ──────────────────────────────────────────────────────
# Set to 'true' when an ESC expects a reversed throttle signal for that motor
# (value → 1 − value before transmission).
MOTOR_A_INVERTED=false
MOTOR_B_INVERTED=false
MOTOR_C_INVERTED=false
MOTOR_D_INVERTED=false

# ── Safe-lift mode ─────────────────────────────────────────────────────────────
# When true, constrains intensity to a safe band, soft-starts via a thrust ramp,
# disables translation, and enables stabilization-only flight.
# SAFE_LIFT_MODE=false   (default) — normal field mode
# SAFE_LIFT_MODE=true    — safe-lift mode active (first real-world lift)
SAFE_LIFT_MODE=false
# Minimum ramp intensity (% of full scale).
SAFE_LIFT_MIN_INTENSITY=10
# Maximum intensity in safe-lift mode (% of full scale, ≤ 35 recommended).
SAFE_LIFT_MAX_INTENSITY=35
# Time (ms) for ramp to travel from min to max intensity (2000–5000 recommended).
SAFE_LIFT_RAMP_DURATION_MS=3000

# ── Tethered test mode ─────────────────────────────────────────────────────────
# When true, same as SAFE_LIFT_MODE but requires TETHER_CONFIRM=true before
# the ramp starts.  Logs every stage: armed / ramp_start / lift_detected / abort.
TETHER_MODE=false
TETHER_CONFIRM=false

# ── Instability detection thresholds ──────────────────────────────────────────
# Maximum absolute roll or pitch angle (radians) before abort is triggered.
# Default: 0.436 rad ≈ 25°
INSTABILITY_MAX_ANGLE_RAD=0.436
# Maximum angular rate magnitude (rad/s) before abort is triggered.
# Default: 1.571 rad/s ≈ 90°/s
INSTABILITY_MAX_RATE_RAD_S=1.571
# Stable-band radius (radians); angles within ±this value are considered stable.
# Default: 0.087 rad ≈ 5°
INSTABILITY_STABLE_BAND_RAD=0.087

# ── Live telemetry stream ──────────────────────────────────────────────────────
# When true, a structured telemetry_tick frame is emitted on every field-loop tick.
# Disable only to reduce log volume in production.
TELEMETRY_ENABLED=true
